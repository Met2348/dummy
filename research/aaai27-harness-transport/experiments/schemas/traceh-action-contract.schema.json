{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/trace-h/action-contract.schema.json",
  "title": "TRACE-H Harness Action Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_id",
    "version",
    "description",
    "allowed_events",
    "max_extra_model_calls",
    "max_extra_env_steps",
    "max_added_tokens",
    "read_only",
    "adds_oracle_information"
  ],
  "properties": {
    "action_id": {"enum": ["NONE", "CHECK", "RETRY", "REPLAN"]},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "description": {"type": "string", "minLength": 1},
    "allowed_events": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "invalid_rejected",
          "no_progress",
          "missing_precondition",
          "pre_submit_uncertainty",
          "budget_pressure"
        ]
      }
    },
    "max_extra_model_calls": {"type": "integer", "minimum": 0},
    "max_extra_env_steps": {"type": "integer", "minimum": 0},
    "max_added_tokens": {"type": "integer", "minimum": 0},
    "read_only": {"type": "boolean"},
    "adds_oracle_information": {"const": false}
  }
}

