{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/trace-h/freeze.schema.json",
  "title": "TRACE-H Policy Transport Freeze",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "freeze_id",
    "created_at",
    "git_commit",
    "environment_lock_hash",
    "model_manifest_hash",
    "task_manifest_hash",
    "action_contract_hash",
    "source_branch_bank_hash",
    "target_baseline_hash",
    "router_artifact_hash",
    "baseline_artifact_hashes",
    "statistics_script_hash",
    "target_action_outcomes_seen_before_freeze"
  ],
  "properties": {
    "freeze_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "git_commit": {"type": "string", "minLength": 7},
    "environment_lock_hash": {"type": "string", "minLength": 12},
    "model_manifest_hash": {"type": "string", "minLength": 12},
    "task_manifest_hash": {"type": "string", "minLength": 12},
    "action_contract_hash": {"type": "string", "minLength": 12},
    "source_branch_bank_hash": {"type": "string", "minLength": 12},
    "target_baseline_hash": {"type": "string", "minLength": 12},
    "router_artifact_hash": {"type": "string", "minLength": 12},
    "baseline_artifact_hashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "minLength": 12}
    },
    "statistics_script_hash": {"type": "string", "minLength": 12},
    "target_action_outcomes_seen_before_freeze": {"const": 0}
  }
}

