{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/forecast-h/episode.schema.json",
  "title": "FORECAST-H Episode Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "task_id",
    "model_id",
    "condition_id",
    "seed",
    "success",
    "intervention_activated",
    "activation_count",
    "steps",
    "input_tokens",
    "output_tokens",
    "wall_time_seconds",
    "infrastructure_failure",
    "started_at",
    "harness_commit"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "task_id": {"type": "string"},
    "model_id": {"type": "string"},
    "condition_id": {"type": "string"},
    "seed": {"type": "integer"},
    "success": {"type": "boolean"},
    "intervention_activated": {"type": "boolean"},
    "activation_count": {"type": "integer", "minimum": 0},
    "steps": {"type": "integer", "minimum": 0},
    "input_tokens": {"type": "integer", "minimum": 0},
    "output_tokens": {"type": "integer", "minimum": 0},
    "wall_time_seconds": {"type": "number", "minimum": 0},
    "infrastructure_failure": {"type": "boolean"},
    "started_at": {"type": "string", "format": "date-time"},
    "harness_commit": {"type": "string", "minLength": 7},
    "trace_path": {"type": "string"},
    "failure_class": {"type": ["string", "null"]}
  }
}

