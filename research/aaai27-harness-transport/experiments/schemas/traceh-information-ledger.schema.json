{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/trace-h/information-ledger.schema.json",
  "title": "TRACE-H Target Information Ledger Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "method_id",
    "source_action_outcomes_seen",
    "target_baseline_episodes_seen",
    "target_action_outcomes_seen_before_test",
    "target_action_outcomes_seen_online",
    "extra_test_time_calls",
    "tokens",
    "steps",
    "wall_clock_seconds"
  ],
  "properties": {
    "method_id": {"type": "string", "minLength": 1},
    "source_action_outcomes_seen": {"type": "integer", "minimum": 0},
    "target_baseline_episodes_seen": {"type": "integer", "minimum": 0},
    "target_action_outcomes_seen_before_test": {"const": 0},
    "target_action_outcomes_seen_online": {"type": "integer", "minimum": 0},
    "extra_test_time_calls": {"type": "integer", "minimum": 0},
    "tokens": {"type": "integer", "minimum": 0},
    "steps": {"type": "integer", "minimum": 0},
    "wall_clock_seconds": {"type": "number", "minimum": 0}
  }
}

