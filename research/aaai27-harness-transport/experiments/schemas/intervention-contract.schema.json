{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/forecast-h/intervention-contract.schema.json",
  "title": "FORECAST-H Atomic Intervention Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intervention_id",
    "version",
    "mechanism_class",
    "changed_surface",
    "trigger",
    "stop_condition",
    "deterministic",
    "max_extra_steps",
    "max_extra_tokens",
    "tool_permissions_unchanged",
    "task_information_added",
    "unit_test_command"
  ],
  "properties": {
    "intervention_id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
    "version": {"type": "string"},
    "mechanism_class": {
      "enum": ["environment_contract", "interface", "verification", "recovery", "context", "prose_guidance"]
    },
    "changed_surface": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["prompt", "tool_schema", "middleware", "state", "verification", "control_flow"]}
    },
    "trigger": {"type": "string", "minLength": 1},
    "stop_condition": {"type": "string", "minLength": 1},
    "deterministic": {"type": "boolean"},
    "stateful": {"type": "boolean"},
    "depends_on_prose_compliance": {"type": "boolean"},
    "max_extra_steps": {"type": "integer", "minimum": 0},
    "max_extra_tokens": {"type": "integer", "minimum": 0},
    "tool_permissions_unchanged": {"const": true},
    "task_information_added": {"type": "string"},
    "unit_test_command": {"type": "string", "minLength": 1}
  }
}

