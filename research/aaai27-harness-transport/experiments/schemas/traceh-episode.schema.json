{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/trace-h/episode.schema.json",
  "title": "TRACE-H Episode Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "information_class",
    "task_id",
    "model_id",
    "checkpoint_hash",
    "precision",
    "policy_id",
    "seed",
    "success",
    "utility",
    "steps",
    "input_tokens",
    "output_tokens",
    "invalid_actions",
    "wall_time_seconds",
    "infrastructure_failure",
    "parser_failure",
    "started_at",
    "harness_commit",
    "config_hash"
  ],
  "properties": {
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,191}$"},
    "information_class": {
      "enum": [
        "DEV_SOURCE_BRANCH",
        "DEV_SOURCE_VALIDATION",
        "DEV_TARGET_BASELINE",
        "DEV_TARGET_FINAL",
        "DEV_POST_SEAL_ORACLE",
        "SOURCE_BRANCH",
        "SOURCE_VALIDATION",
        "TARGET_BASELINE_CALIBRATION",
        "TARGET_FINAL_TEST"
      ]
    },
    "task_id": {"type": "string", "minLength": 1},
    "model_id": {"type": "string", "minLength": 1},
    "checkpoint_hash": {"type": "string", "minLength": 12},
    "precision": {"type": "string", "minLength": 1},
    "policy_id": {"type": "string", "minLength": 1},
    "seed": {"type": "integer", "minimum": 0},
    "success": {"type": "boolean"},
    "utility": {"type": "number"},
    "steps": {"type": "integer", "minimum": 0},
    "input_tokens": {"type": "integer", "minimum": 0},
    "output_tokens": {"type": "integer", "minimum": 0},
    "invalid_actions": {"type": "integer", "minimum": 0},
    "wall_time_seconds": {"type": "number", "minimum": 0},
    "infrastructure_failure": {"type": "boolean"},
    "parser_failure": {"type": "boolean"},
    "started_at": {"type": "string", "format": "date-time"},
    "harness_commit": {"type": "string", "minLength": 7},
    "config_hash": {"type": "string", "minLength": 12},
    "trace_path": {"type": ["string", "null"]},
    "failure_class": {"type": ["string", "null"]}
  }
}

