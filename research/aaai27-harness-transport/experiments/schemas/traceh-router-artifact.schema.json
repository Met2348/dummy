{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/trace-h/router-artifact.schema.json",
  "title": "TRACE-H Frozen Router Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "router_id",
    "version",
    "feature_schema_hash",
    "source_branch_bank_hash",
    "embedding_model",
    "transport",
    "coverage_threshold",
    "lcb_z",
    "action_costs",
    "fallback_action"
  ],
  "properties": {
    "router_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "feature_schema_hash": {"type": "string", "minLength": 12},
    "source_branch_bank_hash": {"type": "string", "minLength": 12},
    "embedding_model": {"type": "string", "minLength": 1},
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reg", "reg_m", "max_match_cost"],
      "properties": {
        "kind": {"const": "unbalanced_partial"},
        "reg": {"type": "number", "exclusiveMinimum": 0},
        "reg_m": {"type": "number", "exclusiveMinimum": 0},
        "max_match_cost": {"type": "number", "minimum": 0}
      }
    },
    "coverage_threshold": {"type": "number", "minimum": 0, "maximum": 1},
    "lcb_z": {"type": "number", "minimum": 0},
    "action_costs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["NONE", "CHECK", "RETRY", "REPLAN"],
      "properties": {
        "NONE": {"const": 0},
        "CHECK": {"type": "number", "minimum": 0},
        "RETRY": {"type": "number", "minimum": 0},
        "REPLAN": {"type": "number", "minimum": 0}
      }
    },
    "fallback_action": {"const": "NONE"}
  }
}

