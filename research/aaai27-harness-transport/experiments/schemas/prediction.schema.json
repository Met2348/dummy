{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/forecast-h/prediction.schema.json",
  "title": "FORECAST-H Sealed Effect Prediction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "target_cell_id",
    "intervention_id",
    "predicted_effect",
    "lower_95",
    "upper_95",
    "negative_transfer_probability",
    "decision",
    "predictor_commit",
    "created_at"
  ],
  "properties": {
    "target_cell_id": {"type": "string"},
    "intervention_id": {"type": "string"},
    "predicted_effect": {"type": "number", "minimum": -1, "maximum": 1},
    "lower_95": {"type": "number", "minimum": -1, "maximum": 1},
    "upper_95": {"type": "number", "minimum": -1, "maximum": 1},
    "negative_transfer_probability": {"type": "number", "minimum": 0, "maximum": 1},
    "decision": {"enum": ["reuse", "retune", "reject"]},
    "predictor_commit": {"type": "string", "minLength": 7},
    "created_at": {"type": "string", "format": "date-time"}
  }
}

