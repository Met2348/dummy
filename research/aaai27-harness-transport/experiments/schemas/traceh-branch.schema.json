{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/trace-h/branch.schema.json",
  "title": "TRACE-H Counterfactual Branch Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "baseline_run_id",
    "task_id",
    "model_id",
    "prefix_id",
    "prefix_state_hash",
    "replayed_state_hash",
    "event_type",
    "action",
    "seed",
    "terminal_utility",
    "none_utility",
    "action_advantage",
    "steps",
    "input_tokens",
    "output_tokens"
  ],
  "properties": {
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,191}$"},
    "baseline_run_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "model_id": {"type": "string", "minLength": 1},
    "prefix_id": {"type": "string", "minLength": 1},
    "prefix_state_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "replayed_state_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "event_type": {
      "enum": [
        "invalid_rejected",
        "no_progress",
        "missing_precondition",
        "pre_submit_uncertainty",
        "budget_pressure"
      ]
    },
    "action": {
      "enum": [
        "NONE",
        "CHECK",
        "RETRY",
        "REPLAN",
        "NATURAL_REPLAN",
        "ANTI_LOOP_RETRY",
        "PRECONDITION_CHECK",
        "SUBGOAL_LEDGER",
        "BUNDLE_CONSERVATIVE"
      ]
    },
    "seed": {"type": "integer", "minimum": 0},
    "terminal_utility": {"type": "number"},
    "none_utility": {"type": "number"},
    "action_advantage": {"type": "number"},
    "steps": {"type": "integer", "minimum": 0},
    "input_tokens": {"type": "integer", "minimum": 0},
    "output_tokens": {"type": "integer", "minimum": 0}
  }
}
